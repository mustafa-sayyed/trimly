  "dependencies": {
    "@packages/db": "workspace:*",
    "@packages/config": "workspace:*",
    "@packages/logging": "workspace:*",
    "@packages/queue": "workspace:*",
    "@sentry/node": "^10.47.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^7.7.0",
    "ua-parser-js": "^2.0.9",
    "winston-transport": "^4.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
