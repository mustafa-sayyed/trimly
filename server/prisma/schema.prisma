generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String
  created_at DateTime @default(now())
  refreshToken String?
  urls       Url[]
}

model Url {
  id         Int         @id @default(autoincrement())
  short_url  String      @unique
  long_url   String
  created_at DateTime    @default(now())
  expires_at DateTime?
  users      User        @relation(fields: [user_id], references: [id])
  user_id    Int
  analytics  Analytics[]

  @@index([short_url])
}

model Analytics {
  id         Int      @id @default(autoincrement())
  click_at   DateTime @default(now())
  user_agent String?
  ip_address String?
  referrer   String?
  url_id     Int      @unique
  url        Url      @relation(fields: [url_id], references: [id])
}
